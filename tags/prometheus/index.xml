&lt;span class="ln">59&lt;/span> &lt;span class="k">def&lt;/span> &lt;span class="nf">init_metadata&lt;/span>&lt;span class="p">(&lt;/span>&lt;span class="bp">self&lt;/span>&lt;span class="p">):&lt;/span>
&lt;span class="ln">60&lt;/span> &lt;span class="n">file_path&lt;/span> &lt;span class="o">=&lt;/span> &lt;span class="n">os&lt;/span>&lt;span class="o">.&lt;/span>&lt;span class="n">path&lt;/span>&lt;span class="o">.&lt;/span>&lt;span class="n">join&lt;/span>&lt;span class="p">(&lt;/span>&lt;span class="bp">self&lt;/span>&lt;span class="o">.&lt;/span>&lt;span class="n">model_uri&lt;/span>&lt;span class="p">,&lt;/span> &lt;span class="s2">&amp;#34;metadata.yaml&amp;#34;&lt;/span>&lt;span class="p">)&lt;/span>
&lt;span class="ln">61&lt;/span>
&lt;span class="ln">62&lt;/span> &lt;span class="k">try&lt;/span>&lt;span class="p">:&lt;/span>
&lt;span class="ln">63&lt;/span> &lt;span class="k">with&lt;/span> &lt;span class="nb">open&lt;/span>&lt;span class="p">(&lt;/span>&lt;span class="n">file_path&lt;/span>&lt;span class="p">,&lt;/span> &lt;span class="s2">&amp;#34;r&amp;#34;&lt;/span>&lt;span class="p">)&lt;/span> &lt;span class="k">as&lt;/span> &lt;span class="n">f&lt;/span>&lt;span class="p">:&lt;/span>
&lt;span class="ln">64&lt;/span> &lt;span class="k">return&lt;/span> &lt;span class="n">yaml&lt;/span>&lt;span class="o">.&lt;/span>&lt;span class="n">safe_load&lt;/span>&lt;span class="p">(&lt;/span>&lt;span class="n">f&lt;/span>&lt;span class="o">.&lt;/span>&lt;span class="n">read&lt;/span>&lt;span class="p">())&lt;/span>
&lt;span class="ln">65&lt;/span> &lt;span class="k">except&lt;/span> &lt;span class="n">FileNotFoundError&lt;/span>&lt;span class="p">:&lt;/span>
&lt;span class="ln">66&lt;/span> &lt;span class="n">logger&lt;/span>&lt;span class="o">.&lt;/span>&lt;span class="n">debug&lt;/span>&lt;span class="p">(&lt;/span>&lt;span class="n">f&lt;/span>&lt;span class="s2">&amp;#34;metadata file {file_path} does not exist&amp;#34;&lt;/span>&lt;span class="p">)&lt;/span>
&lt;span class="ln">67&lt;/span> &lt;span class="k">return&lt;/span> &lt;span class="p">{}&lt;/span>
&lt;span class="ln">68&lt;/span> &lt;span class="k">except&lt;/span> &lt;span class="n">yaml&lt;/span>&lt;span class="o">.&lt;/span>&lt;span class="n">YAMLError&lt;/span>&lt;span class="p">:&lt;/span>
&lt;span class="ln">69&lt;/span> &lt;span class="n">logger&lt;/span>&lt;span class="o">.&lt;/span>&lt;span class="n">error&lt;/span>&lt;span class="p">(&lt;/span>
&lt;span class="ln">70&lt;/span> &lt;span class="n">f&lt;/span>&lt;span class="s2">&amp;#34;metadata file {file_path} present but does not contain valid yaml&amp;#34;&lt;/span>
&lt;span class="ln">71&lt;/span> &lt;span class="p">)&lt;/span>
&lt;span class="ln">72&lt;/span> &lt;span class="k">return&lt;/span> &lt;span class="p">{}&lt;/span>
&lt;span class="ln">73&lt;/span>
&lt;span class="ln">74&lt;/span> &lt;span class="k">def&lt;/span> &lt;span class="nf">metrics&lt;/span>&lt;span class="p">(&lt;/span>&lt;span class="bp">self&lt;/span>&lt;span class="p">)&lt;/span> &lt;span class="o">-&amp;gt;&lt;/span> &lt;span class="n">List&lt;/span>&lt;span class="p">[&lt;/span>&lt;span class="n">Dict&lt;/span>&lt;span class="p">]:&lt;/span>
&lt;span class="ln">75&lt;/span> &lt;span class="k">return&lt;/span> &lt;span class="p">[&lt;/span>
&lt;span class="ln">76&lt;/span> &lt;span class="p">{&lt;/span>
&lt;span class="ln">77&lt;/span> &lt;span class="s2">&amp;#34;type&amp;#34;&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="s2">&amp;#34;COUNTER&amp;#34;&lt;/span>&lt;span class="p">,&lt;/span>
&lt;span class="ln">78&lt;/span> &lt;span class="s2">&amp;#34;key&amp;#34;&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="s2">&amp;#34;call_count&amp;#34;&lt;/span>&lt;span class="p">,&lt;/span>
&lt;span class="ln">79&lt;/span> &lt;span class="s2">&amp;#34;value&amp;#34;&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="mi">1&lt;/span>&lt;span class="p">,&lt;/span>
&lt;span class="ln">80&lt;/span> &lt;span class="p">},&lt;/span> &lt;span class="c1"># a counter which will increase by the given value&lt;/span>
&lt;span class="ln">81&lt;/span> &lt;span class="p">{&lt;/span>
&lt;span class="ln">82&lt;/span> &lt;span class="s2">&amp;#34;type&amp;#34;&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="s2">&amp;#34;COUNTER&amp;#34;&lt;/span>&lt;span class="p">,&lt;/span>
&lt;span class="ln">83&lt;/span> &lt;span class="s2">&amp;#34;key&amp;#34;&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="s2">&amp;#34;data_count&amp;#34;&lt;/span>&lt;span class="p">,&lt;/span>
&lt;span class="ln">84&lt;/span> &lt;span class="s2">&amp;#34;value&amp;#34;&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="bp">self&lt;/span>&lt;span class="o">.&lt;/span>&lt;span class="n">bucket&lt;/span>&lt;span class="p">,&lt;/span>
&lt;span class="ln">85&lt;/span> &lt;span class="p">},&lt;/span> &lt;span class="c1"># a gauge which will be set to given value&lt;/span>
&lt;span class="ln">86&lt;/span> &lt;span class="p">{&lt;/span>
&lt;span class="ln">87&lt;/span> &lt;span class="s2">&amp;#34;type&amp;#34;&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="s2">&amp;#34;GAUGE&amp;#34;&lt;/span>&lt;span class="p">,&lt;/span>
&lt;span class="ln">88&lt;/span> &lt;span class="s2">&amp;#34;key&amp;#34;&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="s2">&amp;#34;data_gauge&amp;#34;&lt;/span>&lt;span class="p">,&lt;/span>
&lt;span class="ln">89&lt;/span> &lt;span class="s2">&amp;#34;value&amp;#34;&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="bp">self&lt;/span>&lt;span class="o">.&lt;/span>&lt;span class="n">bucket&lt;/span>&lt;span class="p">,&lt;/span>
&lt;span class="ln">90&lt;/span> &lt;span class="p">},&lt;/span> &lt;span class="c1"># a gauge which will be set to given value&lt;/span>
&lt;span class="ln">91&lt;/span> &lt;span class="p">{&lt;/span>
&lt;span class="ln">92&lt;/span> &lt;span class="s2">&amp;#34;type&amp;#34;&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="s2">&amp;#34;TIMER&amp;#34;&lt;/span>&lt;span class="p">,&lt;/span>
&lt;span class="ln">93&lt;/span> &lt;span class="s2">&amp;#34;key&amp;#34;&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="s2">&amp;#34;inference_time&amp;#34;&lt;/span>&lt;span class="p">,&lt;/span>
&lt;span class="ln">94&lt;/span> &lt;span class="s2">&amp;#34;value&amp;#34;&lt;/span>&lt;span class="p">:&lt;/span> &lt;span class="bp">self&lt;/span>&lt;span class="o">.&lt;/span>&lt;span class="n">time&lt;/span>&lt;span class="p">,&lt;/span>
&lt;span class="ln">95&lt;/span> &lt;span class="p">},&lt;/span> &lt;span class="c1"># a timer which will add sum and count metrics - assumed millisecs&lt;/span>
&lt;span class="ln">96&lt;/span> &lt;span class="p">]&lt;/span>
&lt;/code>&lt;/pre>&lt;/div>&lt;p>다음 명령어를 이용해 seldon-core를 실행시킵니다.
사용되는 모델은 &lt;a href="https://aiden-jeon.github.io/post/tech/seldon/local/">이전 포스트&lt;/a>를 참고하면 됩니다.&lt;/p>
&lt;div class="highlight">&lt;pre class="chroma">&lt;code class="language-bash" data-lang="bash">&lt;span class="ln">1&lt;/span>seldon-core-microservice MLFlowServer --parameters &lt;span class="s1">&amp;#39;[{&amp;#34;name&amp;#34;: &amp;#34;model_uri&amp;#34;, &amp;#34;type&amp;#34;:&amp;#34;STRING&amp;#34;, &amp;#34;value&amp;#34;: &amp;#34;file://mlruns/0/d96ad56315364063901ace2df62dfbc2/artifacts/iris_model/&amp;#34;}]&amp;#39;&lt;/span>
&lt;/code>&lt;/pre>&lt;/div>&lt;h2 id="prometheus">Prometheus&lt;/h2>
&lt;p>prometheus에서 사용할 config 파일 &lt;code>prometheus.yaml&lt;/code>을 작성합니다.
이 때 target port는 6000입니다.&lt;/p>
&lt;div class="highlight">&lt;pre class="chroma">&lt;code class="language-yaml" data-lang="yaml">&lt;span class="ln"> 1&lt;/span>&lt;span class="nt">global&lt;/span>&lt;span class="p">:&lt;/span>&lt;span class="w">
&lt;/span>&lt;span class="ln"> 2&lt;/span>&lt;span class="w"> &lt;/span>&lt;span class="nt">scrape_interval&lt;/span>&lt;span class="p">:&lt;/span>&lt;span class="w"> &lt;/span>&lt;span class="l">15s&lt;/span>&lt;span class="w">
&lt;/span>&lt;span class="ln"> 3&lt;/span>&lt;span class="w"> &lt;/span>&lt;span class="nt">evaluation_interval&lt;/span>&lt;span class="p">:&lt;/span>&lt;span class="w"> &lt;/span>&lt;span class="l">15s&lt;/span>&lt;span class="w">
&lt;/span>&lt;span class="ln"> 4&lt;/span>&lt;span class="w">
&lt;/span>&lt;span class="ln"> 5&lt;/span>&lt;span class="w">&lt;/span>&lt;span class="nt">rule_files&lt;/span>&lt;span class="p">:&lt;/span>&lt;span class="w">
&lt;/span>&lt;span class="ln"> 6&lt;/span>&lt;span class="w"> &lt;/span>&lt;span class="c"># - &amp;#34;first.rules&amp;#34;&lt;/span>&lt;span class="w">
&lt;/span>&lt;span class="ln"> 7&lt;/span>&lt;span class="w"> &lt;/span>&lt;span class="c"># - &amp;#34;second.rules&amp;#34;&lt;/span>&lt;span class="w">
&lt;/span>&lt;span class="ln"> 8&lt;/span>&lt;span class="w">
&lt;/span>&lt;span class="ln"> 9&lt;/span>&lt;span class="w">&lt;/span>&lt;span class="nt">scrape_configs&lt;/span>&lt;span class="p">:&lt;/span>&lt;span class="w">
&lt;/span>&lt;span class="ln">10&lt;/span>&lt;span class="w"> &lt;/span>- &lt;span class="nt">job_name&lt;/span>&lt;span class="p">:&lt;/span>&lt;span class="w"> &lt;/span>&lt;span class="l">prometheus&lt;/span>&lt;span class="w">
&lt;/span>&lt;span class="ln">11&lt;/span>&lt;span class="w"> &lt;/span>&lt;span class="nt">static_configs&lt;/span>&lt;span class="p">:&lt;/span>&lt;span class="w">
&lt;/span>&lt;span class="ln">12&lt;/span>&lt;span class="w"> &lt;/span>- &lt;span class="nt">targets&lt;/span>&lt;span class="p">:&lt;/span>&lt;span class="w"> &lt;/span>&lt;span class="p">[&lt;/span>&lt;span class="s1">&amp;#39;localhost:6000&amp;#39;&lt;/span>&lt;span class="p">]&lt;/span>&lt;span class="w">
&lt;/span>&lt;/code>&lt;/pre>&lt;/div>&lt;p>prometheus를 실행합니다.&lt;/p>
&lt;div class="highlight">&lt;pre class="chroma">&lt;code class="language-bash" data-lang="bash">&lt;span class="ln">1&lt;/span>prometheus --config.file&lt;span class="o">=&lt;/span>prometheus.yaml
&lt;/code>&lt;/pre>&lt;/div>&lt;p>predict 를 합니다.&lt;/p>
&lt;div class="highlight">&lt;pre class="chroma">&lt;code class="language-bash" data-lang="bash">&lt;span class="ln">1&lt;/span>curl -H &lt;span class="s2">&amp;#34;Content-Type: application/json&amp;#34;&lt;/span> http://localhost:9000/predict -d @./input.json
&lt;/code>&lt;/pre>&lt;/div>&lt;p>다음과 같은 결과를 얻습니다.&lt;/p>
&lt;div class="highlight">&lt;pre class="chroma">&lt;code class="language-bash" data-lang="bash">&lt;span class="ln">1&lt;/span>&lt;span class="o">{&lt;/span>&lt;span class="s2">&amp;#34;data&amp;#34;&lt;/span>:&lt;span class="o">{&lt;/span>&lt;span class="s2">&amp;#34;names&amp;#34;&lt;/span>****:&lt;span class="o">[]&lt;/span>,&lt;span class="s2">&amp;#34;ndarray&amp;#34;&lt;/span>:&lt;span class="o">[&lt;/span>1,1&lt;span class="o">]}&lt;/span>,&lt;span class="s2">&amp;#34;meta&amp;#34;&lt;/span>:&lt;span class="o">{&lt;/span>&lt;span class="s2">&amp;#34;metrics&amp;#34;&lt;/span>:&lt;span class="o">[{&lt;/span>&lt;span class="s2">&amp;#34;key&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;call_count&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;type&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;COUNTER&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;value&amp;#34;&lt;/span>:1&lt;span class="o">}&lt;/span>,&lt;span class="o">{&lt;/span>&lt;span class="s2">&amp;#34;key&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;data_count&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;type&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;COUNTER&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;value&amp;#34;&lt;/span>:2&lt;span class="o">}&lt;/span>,&lt;span class="o">{&lt;/span>&lt;span class="s2">&amp;#34;key&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;data_gauge&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;type&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;GAUGE&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;value&amp;#34;&lt;/span>:2&lt;span class="o">}&lt;/span>,&lt;span class="o">{&lt;/span>&lt;span class="s2">&amp;#34;key&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;inference_time&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;type&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;TIMER&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;value&amp;#34;&lt;/span>:4.001783132553101&lt;span class="o">}]}}&lt;/span>
&lt;/code>&lt;/pre>&lt;/div>&lt;p>&lt;a href="http://localhost:9090">http://localhost:9090&lt;/a> 으로 접속하면 prometheus ui를 볼 수 있습니다.
&lt;img src="https://aiden-jeon.github.io/imgs/seldon/prometheus-1.png" alt="img-1">&lt;/p>
&lt;p>다음과 같이 볼 metric을 정하면 결과를 볼 수 잇씁니다.
&lt;img src="https://aiden-jeon.github.io/imgs/seldon/prometheus-2.png" alt="img-2">&lt;/p>
&lt;p>이제 predict를 몇 번 더 실행 시켜보겠습니다.&lt;/p>
&lt;div class="highlight">&lt;pre class="chroma">&lt;code class="language-bash" data-lang="bash">&lt;span class="ln">1&lt;/span>❯ curl -H &lt;span class="s2">&amp;#34;Content-Type: application/json&amp;#34;&lt;/span> http://localhost:9000/predict -d @./input.json
&lt;span class="ln">2&lt;/span>&lt;span class="o">{&lt;/span>&lt;span class="s2">&amp;#34;data&amp;#34;&lt;/span>:&lt;span class="o">{&lt;/span>&lt;span class="s2">&amp;#34;names&amp;#34;&lt;/span>:&lt;span class="o">[]&lt;/span>,&lt;span class="s2">&amp;#34;ndarray&amp;#34;&lt;/span>:&lt;span class="o">[&lt;/span>1,1&lt;span class="o">]}&lt;/span>,&lt;span class="s2">&amp;#34;meta&amp;#34;&lt;/span>:&lt;span class="o">{&lt;/span>&lt;span class="s2">&amp;#34;metrics&amp;#34;&lt;/span>:&lt;span class="o">[{&lt;/span>&lt;span class="s2">&amp;#34;key&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;call_count&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;type&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;COUNTER&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;value&amp;#34;&lt;/span>:1&lt;span class="o">}&lt;/span>,&lt;span class="o">{&lt;/span>&lt;span class="s2">&amp;#34;key&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;data_count&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;type&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;COUNTER&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;value&amp;#34;&lt;/span>:2&lt;span class="o">}&lt;/span>,&lt;span class="o">{&lt;/span>&lt;span class="s2">&amp;#34;key&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;data_gauge&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;type&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;GAUGE&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;value&amp;#34;&lt;/span>:2&lt;span class="o">}&lt;/span>,&lt;span class="o">{&lt;/span>&lt;span class="s2">&amp;#34;key&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;inference_time&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;type&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;TIMER&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;value&amp;#34;&lt;/span>:4.003461837768555&lt;span class="o">}]}}&lt;/span>
&lt;span class="ln">3&lt;/span>❯ curl -H &lt;span class="s2">&amp;#34;Content-Type: application/json&amp;#34;&lt;/span> http://localhost:9000/predict -d @./input.json
&lt;span class="ln">4&lt;/span>&lt;span class="o">{&lt;/span>&lt;span class="s2">&amp;#34;data&amp;#34;&lt;/span>:&lt;span class="o">{&lt;/span>&lt;span class="s2">&amp;#34;names&amp;#34;&lt;/span>:&lt;span class="o">[]&lt;/span>,&lt;span class="s2">&amp;#34;ndarray&amp;#34;&lt;/span>:&lt;span class="o">[&lt;/span>1,1&lt;span class="o">]}&lt;/span>,&lt;span class="s2">&amp;#34;meta&amp;#34;&lt;/span>:&lt;span class="o">{&lt;/span>&lt;span class="s2">&amp;#34;metrics&amp;#34;&lt;/span>:&lt;span class="o">[{&lt;/span>&lt;span class="s2">&amp;#34;key&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;call_count&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;type&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;COUNTER&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;value&amp;#34;&lt;/span>:1&lt;span class="o">}&lt;/span>,&lt;span class="o">{&lt;/span>&lt;span class="s2">&amp;#34;key&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;data_count&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;type&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;COUNTER&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;value&amp;#34;&lt;/span>:2&lt;span class="o">}&lt;/span>,&lt;span class="o">{&lt;/span>&lt;span class="s2">&amp;#34;key&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;data_gauge&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;type&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;GAUGE&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;value&amp;#34;&lt;/span>:2&lt;span class="o">}&lt;/span>,&lt;span class="o">{&lt;/span>&lt;span class="s2">&amp;#34;key&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;inference_time&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;type&amp;#34;&lt;/span>:&lt;span class="s2">&amp;#34;TIMER&amp;#34;&lt;/span>,&lt;span class="s2">&amp;#34;value&amp;#34;&lt;/span>:3.003340005874634&lt;span class="o">}]}}&lt;/span>
&lt;/code>&lt;/pre>&lt;/div>&lt;p>다음과 같이 그래프가 변하는 것을 확인할 수 있습니다.
&lt;img src="https://aiden-jeon.github.io/imgs/seldon/prometheus-3.png" alt="img-3">&lt;/p></description></item></channel></rss>